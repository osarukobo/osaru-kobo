# TimeTree Personal Access Token
# 取得先: https://timetreeapp.com/personal_access_tokens
TIMETREE_TOKEN=your_timetree_token_here

# freee APIアクセストークン
# 取得先: https://developer.freee.co.jp/ → アプリ登録 → アクセストークン発行
FREEE_ACCESS_TOKEN=your_freee_access_token_here

# freee 事業所ID
# freee管理画面のURLに含まれる数字: https://secure.freee.co.jp/companies/<ここ>/...
FREEE_COMPANY_ID=your_company_id_here
